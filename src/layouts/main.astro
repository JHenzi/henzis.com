---
import '../styles/global.css';
import { Header } from '@/components/Header';
import { Footer } from '@/components/Footer';
import { CommandPalette } from '@/components/CommandPalette';
import { CookieConsent } from '@/components/CookieConsent';
const { title = "Henzi's Services LLC - Tools Built for Humans" } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content="Henzi's Services LLC builds tools for humans: MLS Writer, Pacalaca, and VOTE." />
		<link rel="icon" type="image/png" href="/HenziServicesLogo.png" />
		<title>{title}</title>
	</head>
	<body>
		<Header client:load />
		<main>
			<slot />
		</main>
		<Footer />
		<CommandPalette client:load />
		<CookieConsent client:load />
	</body>
</html>
